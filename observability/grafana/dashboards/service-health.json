{
  "title": "FlowCommerce — Service Health",
  "uid": "fc-service-health",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {
      "id": 1, "title": "Service / dependency status (up)", "type": "state-timeline",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "targets": [{"expr": "up{job=\"order-platform\"}", "legendFormat": "{{service}}"}]
    },
    {
      "id": 2, "title": "Per-service request rate", "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "targets": [{"expr": "sum by (service) (rate(op_http_requests_total[1m]))", "legendFormat": "{{service}}"}]
    },
    {
      "id": 3, "title": "Per-service 5xx error rate", "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "targets": [{"expr": "sum by (service) (rate(op_http_errors_total[5m]))", "legendFormat": "{{service}}"}]
    },
    {
      "id": 4, "title": "Per-service request latency p95", "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, service) (rate(op_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{service}}"}]
    }
  ]
}
