# ─────────────────────────────────────────────────────────────────────────
# FlowCommerce AI — production environment template
# Copy values into each Render service's Environment tab (and Vercel for VITE_*).
# DO NOT commit real secrets. This file contains placeholders only.
# ─────────────────────────────────────────────────────────────────────────

# ── Shared by ALL backend services ───────────────────────────────────────
# JWT_SECRET must be IDENTICAL across every service or tokens won't validate.
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRY_HOURS=24

# Neon Postgres — include sslmode=require
POSTGRES_DSN=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/orders?sslmode=require

# Confluent Cloud Kafka (SASL_SSL / PLAIN)
KAFKA_BOOTSTRAP=pkc-xxxxx.REGION.aws.confluent.cloud:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_USERNAME=CONFLUENT_API_KEY
KAFKA_PASSWORD=CONFLUENT_API_SECRET

# ── order-service + stripe-webhook-service ───────────────────────────────
# Upstash Redis (TLS) — used by order-service health checks
REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379

# CORS: production frontend origin (comma-separated for multiple)
FRONTEND_ORIGIN=https://your-app.vercel.app

# Inter-service URLs (order-service calls siblings for /admin/system-health + copilot)
AUTH_SERVICE_URL=https://flowcommerce-auth.onrender.com
CATALOG_SERVICE_URL=https://flowcommerce-catalog.onrender.com
ORDER_SERVICE_URL=https://flowcommerce-order.onrender.com
INVENTORY_SERVICE_URL=https://flowcommerce-inventory.onrender.com
PAYMENT_SERVICE_URL=https://flowcommerce-payment.onrender.com
NOTIFICATION_SERVICE_URL=https://flowcommerce-notification.onrender.com
STRIPE_WEBHOOK_SERVICE_URL=https://flowcommerce-webhook.onrender.com

# ── payment-service + order-service (Stripe) ─────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_xxx
PAYMENT_FAILURE_RATE=0.0

# ── stripe-webhook-service ───────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── notification-service (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_xxx
FROM_EMAIL=orders@yourdomain.com

# ── order-service (optional AI copilot LLM) ──────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ─────────────────────────────────────────────────────────────────────────
# FRONTEND (set these in Vercel → Project → Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────────────────
VITE_AUTH_URL=https://flowcommerce-auth.onrender.com
VITE_CATALOG_URL=https://flowcommerce-catalog.onrender.com
VITE_ORDERS_URL=https://flowcommerce-order.onrender.com
VITE_STRIPE_PUBLIC_KEY=pk_live_or_test_xxx
